# OAP Email Scanner configuration
#
# Copy to config.yaml and fill in your IMAP credentials.
# Password can also be set via OAP_EMAIL_PASSWORD env var.

imap:
  host: "imap.gmail.com"         # IMAP server hostname
  port: 993                       # IMAP port (993 for SSL)
  username: "you@gmail.com"       # Email address
  password: "your-app-password"   # App password (not your login password)
  use_ssl: true
  folders:
    - "INBOX"
    # - "[Gmail]/Sent Mail"
    # - "[Gmail]/Starred"

database:
  path: "oap_email.db"

api:
  host: "127.0.0.1"
  port: 8305

# Max messages to keep cached per folder
max_cached: 500

# Default scan window when no 'since' parameter provided (hours)
default_scan_hours: 24

# LLM email classifier — categorizes and prioritizes messages
classifier:
  enabled: false                        # Set to true to enable classification
  model: "qwen3:14b"                    # Ollama model for classification
  ollama_url: "http://localhost:11434"   # Ollama API endpoint
  timeout: 30                           # Per-message timeout (seconds)
  use_escalation: false                 # Use big LLM (from escalation config) for better accuracy

  # Sender overrides — force category/priority without LLM classification.
  # DB overrides (set via chat: "mark emails from X as important") take precedence.
  # sender_overrides:
  #   "mycpa@accounting.com":
  #     category: personal
  #     priority: important
  #   "@facebookmail.com":
  #     priority: noise
  #   "@bankofamerica.com":
  #     priority: urgent

# Spam pre-filter — fast tiers that run before the expensive LLM
# Catches definitive spam without touching Haiku/Sonnet.
# Tier order: blocked_domains → x-spam-status header → local model → full LLM
# spam_filter:
#   enabled: true
#   local_model: "qwen3:1.7b"        # Fast local spam/ham binary check
#   spam_threshold: 0.85             # Only auto-classify spam above this confidence
#   blocked_domains:                 # Instant spam, no model call
#     - "spam-kingdom.com"

# Big LLM for classification (optional — used when classifier.use_escalation: true)
# escalation:
#   enabled: true
#   provider: anthropic
#   model: claude-sonnet-4-6
#   timeout: 30

# Auto-file classified messages to IMAP folders
auto_file:
  enabled: false
  folders:
    personal: INBOX
    machine: machine
    mailing-list: mailing-list
    spam: spam
    offers: offers

# Email Manager — autonomous inbox management
# manager:
#   enabled: false                     # opt-in
#   archive_enabled: true              # allow archiving via preferences
#   unsubscribe_enabled: true          # allow List-Unsubscribe GET requests
#   draft_reply_enabled: false         # generate draft replies (requires smtp config)
#   archive_folder: "archive"          # IMAP folder name for archived messages
#   use_escalation: false              # use Claude for draft generation (better quality)
#   ollama_model: "qwen3:8b"          # local model for draft generation

# SMTP — required for sending approved draft replies (manager.draft_reply_enabled)
# smtp:
#   host: "smtp.gmail.com"
#   port: 587
#   username: "you@gmail.com"
#   password: "your-app-password"     # or OAP_SMTP_PASSWORD env var
#   use_tls: true
